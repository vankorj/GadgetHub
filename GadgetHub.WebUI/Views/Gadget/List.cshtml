@model GadgetHub.WebUI.Models.GadgetsListViewModel
@using GadgetHub.WebUI.HtmlHelpers

@{
    ViewBag.Title = "Gadgets";
}

@foreach (var p in Model.Gadgets)
{
    <div class="well">
        <h3>
            <strong>@p.Name</strong>
            <span class="pull-right label label-primary">
                @p.Price.ToString("c")
            </span>
        </h3>
        <span class="lead"> @p.Description </span>
    </div>
}

<div class="btn-group pull-right">
    @Html.PageLinks(Model.PagingInfo,
        x => Url.Action("List", new { page = x }))
</div>
