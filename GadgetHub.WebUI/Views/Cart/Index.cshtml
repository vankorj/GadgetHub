@model GadgetHub.WebUI.Models.CartIndexViewModel

<div class="container mt-4">
    <h2>Your Cart</h2>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Quantity</th>
                <th>Item</th>
                <th class="text-end">Price</th>
                <th class="text-end">Subtotal</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var line in Model.Cart.Lines)
            {
                <tr>
                    <td>@line.Quantity</td>
                    <td>@line.Gadget.Name</td>
                    <td class="text-end">$@line.Gadget.Price</td>
                    <td class="text-end">
                        $@(line.Quantity * line.Gadget.Price)
                    </td>
                    <td>
                        @using (Html.BeginForm("RemoveFromCart", "Cart"))
                        {
                            @Html.Hidden("id", line.Gadget.Id)
                            @Html.Hidden("returnUrl", Model.ReturnUrl)

                            <button class="btn btn-danger btn-sm">
                                Remove
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-end">
        <h4>Total: $@Model.Cart.ComputeTotalValue()</h4>
    </div>

    <div class="mt-3 d-flex justify-content-between">
        <a href="@Model.ReturnUrl" class="btn btn-secondary">
            Continue Shopping
        </a>
    </div>
</div>